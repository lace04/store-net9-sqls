@{
    ViewData["Title"] = "Home Page";
}

<section class="py-16">
  <h1 class="font-nantes text-ink-black text-[28px] leading-[1.43] mb-4">Welcome to Store</h1>
  <p class="text-charcoal text-body mb-8 max-w-lg">Manage your products, categories, and orders in one place.</p>
  <div>
    <a asp-controller="Category" asp-action="Index" class="inline-flex items-center px-6 py-2.5 bg-ink-black text-pure-white text-sm rounded-buttons hover:bg-charcoal focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ink-black">
      Browse Categories
    </a>
  </div>
</section>