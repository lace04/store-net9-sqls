@{
    ViewData["Title"] = "Home Page";
}

<section class="text-center py-12">
  <h1 class="text-4xl font-bold text-primary mb-4">Welcome to Store</h1>
  <p class="text-lg text-primary-light mb-8">Manage your products, categories, and orders in one place.</p>
  <div class="flex justify-center gap-4">
    <a asp-controller="Category" asp-action="Index" class="inline-flex items-center px-6 py-3 bg-accent text-white font-medium rounded-md hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent">
      Browse Categories
    </a>
  </div>
</section>