<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Store management system - Manage your products, categories, and orders" />
    @if (ViewData["Robots"] is string robots)
    {
      <meta name="robots" content="@robots" />
    }
    <title>@ViewData["Title"] - Store</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link
      rel="stylesheet"
      href="~/Store.styles.css"
      asp-append-version="true"
    />
    @RenderSection("Styles", required: false)
  </head>
  <body class="flex flex-col min-h-screen bg-cream-paper font-graphik">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-pure-white focus:text-ink-black focus:rounded-[4px]">Skip to main content</a>
    <header>
      <nav aria-label="Main navigation" class="bg-pure-white border-b border-ash">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center">
              <a class="text-xl font-medium text-ink-black tracking-wider" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Store home">Store</a>
            </div>
            <div class="hidden sm:flex sm:items-center sm:space-x-1">
              <a class="text-charcoal hover:text-ink-black hover:bg-cream-paper px-3 py-2 rounded-pills text-sm" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
              <a class="text-charcoal hover:text-ink-black hover:bg-cream-paper px-3 py-2 rounded-pills text-sm" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
              <a class="text-charcoal hover:text-ink-black hover:bg-cream-paper px-3 py-2 rounded-pills text-sm" asp-area="" asp-controller="Category" asp-action="Index">Categories</a>
              <a class="text-charcoal hover:text-ink-black hover:bg-cream-paper px-3 py-2 rounded-pills text-sm" asp-area="" asp-controller="Product" asp-action="Index">Products</a>
            </div>
            <div class="flex items-center sm:hidden">
              <button
                id="menu-toggle"
                type="button"
                class="text-charcoal hover:text-ink-black focus:outline-none p-2"
                aria-label="Toggle navigation"
                aria-controls="mobile-menu"
                aria-expanded="false"
              >
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
              </button>
            </div>
          </div>
          <div id="mobile-menu" class="hidden sm:hidden pb-4 space-y-1" role="region" aria-label="Mobile navigation">
            <a class="block text-charcoal hover:text-ink-black hover:bg-cream-paper px-3 py-2 rounded-pills text-sm" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
            <a class="block text-charcoal hover:text-ink-black hover:bg-cream-paper px-3 py-2 rounded-pills text-sm" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            <a class="block text-charcoal hover:text-ink-black hover:bg-cream-paper px-3 py-2 rounded-pills text-sm" asp-area="" asp-controller="Category" asp-action="Index">Categories</a>
            <a class="block text-charcoal hover:text-ink-black hover:bg-cream-paper px-3 py-2 rounded-pills text-sm" asp-area="" asp-controller="Product" asp-action="Index">Products</a>
          </div>
        </div>
      </nav>
    </header>
    <main id="main-content" class="flex-1" role="main">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
        @RenderBody()
      </div>
    </main>

    <footer role="contentinfo" class="border-t border-ash bg-cream-paper">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4 text-sm text-smoke">
        &copy; @DateTime.Now.Year - Store -
        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-ink-black hover:text-charcoal underline">Privacy</a>
      </div>
    </footer>
    <!-- Confirm delete modal -->
    <div id="confirm-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden" role="dialog" aria-modal="true" aria-labelledby="confirm-title">
      <div class="fixed inset-0 bg-ink-black/40" onclick="hideConfirmModal()" aria-hidden="true"></div>
      <div id="modal-card" class="relative bg-pure-white rounded-cards border border-ash mx-4 p-6 w-full max-w-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center w-8 h-8 rounded-cards bg-ink-black/5 shrink-0">
            <svg class="w-4 h-4 text-ink-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <p id="confirm-title" class="text-sm text-charcoal tracking-[0.009em]">
            Are you sure you want to delete <strong id="confirm-item-name" class="text-ink-black"></strong>?
          </p>
        </div>
        <div class="flex items-center justify-end gap-3 pt-4 border-t border-ash">
          <button type="button" onclick="hideConfirmModal()"
            class="px-4 py-2 text-sm text-smoke hover:text-charcoal rounded-buttons hover:bg-cream-paper focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ink-black">
            Cancel
          </button>
          <button type="button" onclick="submitDelete()"
            class="px-4 py-2 text-sm text-pure-white bg-ink-black rounded-buttons hover:bg-charcoal focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ink-black">
            Delete
          </button>
        </div>
      </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
  </body>
</html>