@model List<CategoryVM>

<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-semibold text-primary">Categories</h1>
  <a
    asp-action="Create"
    class="inline-flex items-center gap-2 px-4 py-2 bg-accent text-white text-sm font-medium rounded-md hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent"
    aria-label="Create new category"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
    </svg>
    Create new
  </a>
</div>

<hr class="mb-6 border-border" />

@if (Model.Count == 0)
{
  <div class="text-center py-12 text-gray-500" role="status">
    <p class="text-lg">No categories found</p>
    <p class="text-sm mt-1">Get started by creating a new category.</p>
  </div>
}
else
{
  <div class="overflow-x-auto bg-white rounded-lg shadow-sm border border-border">
    <table class="min-w-full divide-y divide-border">
      <caption class="sr-only">List of product categories</caption>
      <thead>
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-primary uppercase tracking-wider">#</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-primary uppercase tracking-wider">Name</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-primary uppercase tracking-wider">Description</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-primary uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        @foreach (var category in Model) {
          <tr class="hover:bg-gray-50 even:bg-surface">
            <th scope="row" class="px-6 py-4 whitespace-nowrap text-sm font-medium text-primary">@category.CategoryId</th>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-primary-light">@category.Name</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@category.Description</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
              <form method="post" asp-action="Edit" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@category.CategoryId" />
                <button type="submit"
                  class="inline-flex items-center justify-center p-2 text-primary-light hover:text-primary hover:bg-gray-100 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
                  aria-label="Edit category @category.Name"
                  title="Edit category"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                </button>
              </form>
              <form method="post" asp-action="Delete" class="inline" onsubmit="return confirm('Are you sure you want to delete this category?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@category.CategoryId" />
                <button type="submit"
                  class="inline-flex items-center justify-center p-2 text-red-600 hover:text-red-800 hover:bg-red-50 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
                  aria-label="Delete category @category.Name"
                  title="Delete category"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </form>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}