@model List<CategoryVM>

@if (TempData["Success"] is string successMsg)
{
  <div class="bg-pure-white border border-ash text-charcoal px-4 py-3 rounded-cards mb-4 tracking-[0.009em]" role="alert">
    <span class="font-medium">&#10003;</span> @successMsg
  </div>
}

@if (TempData["Error"] is string errorMsg)
{
  <div class="bg-pure-white border border-ash text-ink-black px-4 py-3 rounded-cards mb-4 tracking-[0.009em]" role="alert">
    <span class="font-medium">&#33;</span> @errorMsg
  </div>
}

<div class="flex justify-between items-center mb-4">
  <h1 class="font-nantes text-ink-black text-[22px] leading-[1.45]">Categories</h1>
  <a
    asp-action="AddEdit"
    class="inline-flex items-center gap-2 px-4 py-2 bg-ink-black text-pure-white text-sm rounded-buttons hover:bg-charcoal focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ink-black"
    aria-label="Create new category"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
    </svg>
    Create new
  </a>
</div>

<hr class="mb-6 border-ash" />

@if (Model.Count == 0)
{
  <div class="text-center py-12 text-smoke" role="status">
    <p class="text-body">No categories found</p>
    <p class="text-caption mt-1">Get started by creating a new category.</p>
  </div>
}
else
{
  <div class="overflow-x-auto bg-pure-white rounded-cards border border-ash">
    <table class="min-w-full divide-y divide-ash">
      <caption class="sr-only">List of product categories</caption>
      <thead>
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs text-ink-black uppercase tracking-wider">#</th>
          <th scope="col" class="px-6 py-3 text-left text-xs text-ink-black uppercase tracking-wider">Name</th>
          <th scope="col" class="px-6 py-3 text-left text-xs text-ink-black uppercase tracking-wider">Description</th>
          <th scope="col" class="px-6 py-3 text-left text-xs text-ink-black uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ash">
        @foreach (var category in Model) {
          <tr class="hover:bg-cream-paper even:bg-cream-paper">
            <th scope="row" class="px-6 py-4 whitespace-nowrap text-sm text-charcoal">@category.CategoryId</th>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-charcoal">@category.Name</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-smoke">@category.Description</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
              <a asp-action="AddEdit" asp-route-id="@category.CategoryId"
                class="inline-flex items-center justify-center p-2 text-charcoal hover:text-ink-black hover:bg-cream-paper rounded-cards focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ink-black"
                aria-label="Edit category @category.Name"
                title="Edit category"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              </a>
              @if (category.ProductCount == 0)
              {
                <form method="post" asp-action="Delete" class="inline" onsubmit="return confirm('Are you sure you want to delete this category?');">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="id" value="@category.CategoryId" />
                  <button type="submit"
                    class="inline-flex items-center justify-center p-2 text-smoke hover:text-ink-black hover:bg-cream-paper rounded-cards focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ink-black"
                    aria-label="Delete category @category.Name"
                    title="Delete category"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </form>
              }
              else
              {
                <span class="relative inline-flex group">
                  <svg class="w-4 h-4 text-smoke cursor-help" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-1.5 bg-ink-black text-pure-white text-xs rounded-cards whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                    @category.ProductCount product(s) assigned. Reassign or delete them first.
                  </span>
                </span>
              }
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
